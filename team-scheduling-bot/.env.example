# Required — get from https://console.chronary.ai
CHRONARY_API_KEY=chr_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — Alice's real Google/Outlook calendar iCal URL.
# When set, the script subscribes Alice's agent to your real calendar so that
# cross-agent availability respects what's already on your phone.
# In Google Calendar: Settings → Integrate calendar → "Secret address in iCal format".
# Leave blank to skip iCal subscription.
ALICE_ICAL_URL=
